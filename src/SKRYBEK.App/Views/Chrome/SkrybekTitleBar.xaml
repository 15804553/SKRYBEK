<UserControl x:Class="SKRYBEK.App.Views.Chrome.SkrybekTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource TitleBarBrush}"
            Height="32">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Ikona -->
            <Image Grid.Column="0"
                   Source="/Resources/skrybek.ico"
                   Width="20" Height="20"
                   Margin="8,0,4,0"
                   VerticalAlignment="Center" />

            <!-- Tytuł -->
            <TextBlock Grid.Column="1"
                       x:Name="TitleText"
                       Text="SKRYBEK"
                       Foreground="{StaticResource ForegroundBrush}"
                       FontWeight="Bold"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0" />

            <!-- Obszar przeciągania -->
            <Border Grid.Column="2"
                    x:Name="DragArea"
                    Background="Transparent"
                    MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
                    MouseMove="DragArea_MouseMove" />

            <!-- Przyciski Chrome -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource ChromeIconButton}"
                        Content="─"
                        ToolTip="Minimalizuj"
                        Click="MinimizeButton_Click" />
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource ChromeIconButton}"
                        Content="□"
                        ToolTip="Maksymalizuj"
                        Click="MaximizeButton_Click" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource ChromeCloseButton}"
                        Content="✕"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
