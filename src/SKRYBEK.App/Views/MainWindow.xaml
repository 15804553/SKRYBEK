<Window x:Class="SKRYBEK.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:SKRYBEK.App.Views.Chrome"
        xmlns:views="clr-namespace:SKRYBEK.App.Views"
        xmlns:vm="clr-namespace:SKRYBEK.App.ViewModels"
        Title="SKRYBEK"
        Icon="/Resources/skrybek.ico"
        Height="900" Width="1400"
        MinHeight="650" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Custom TitleBar -->
            <chrome:SkrybekTitleBar Grid.Row="0"
                                     Title="SKRYBEK — Rozkaz Dzienny JRG"
                                     ShowMinimizeButton="True"
                                     ShowMaximizeButton="True" />

            <!-- Pasek narzędzi -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Lewa strona: akcje -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="＋  Nowy rozkaz"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding NowyRozkazCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Margin="0,0,8,0" />
                        <ComboBox x:Name="RokCombo"
                                  IsEditable="True"
                                  Style="{StaticResource DarkComboBox}"
                                  Width="80"
                                  SelectedItem="{Binding AktualnyRok}"
                                  SelectionChanged="RokCombo_SelectionChanged"
                                  Margin="0,0,8,0" />
                    </StackPanel>

                    <!-- Prawa strona: sesja -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="UserLabel"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Margin="0,0,16,0" />
                        <Button Content="Ustawienia"
                                Style="{StaticResource SecondaryButton}"
                                Click="Settings_Click"
                                Margin="0,0,8,0" />
                        <Button Content="Wyloguj"
                                Style="{StaticResource SecondaryButton}"
                                Click="Logout_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Treść: NavigationPanel + Editor -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="380" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Panel nawigacyjny — lista rozkazów -->
                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="ROZKAZY"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="12,10,12,6" />

                        <ListBox Grid.Row="1"
                                 x:Name="RozkazyList"
                                 ItemsSource="{Binding Rozkazy}"
                                 SelectedItem="{Binding WybranyRozkaz}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="RozkazyList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource ForegroundBrush}">
                                                <Run Text="Nr " /><Run Text="{Binding NumerFormatowany, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                                       Text="{Binding DataFormatowana, Mode=OneWay}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Style="{StaticResource ChromeIconButton}"
                                                Width="22" Height="22" FontSize="10"
                                                Visibility="{Binding DataContext.CanEdit,
                                                             RelativeSource={RelativeSource AncestorType=Window},
                                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                                Tag="{Binding}"
                                                Click="DeleteRozkaz_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Panel edytora rozkazu -->
                <Border Grid.Column="2" Background="{StaticResource BackgroundBrush}">
                    <ContentControl x:Name="EditorHost" Content="{Binding EditorVm}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:RozkazEditorViewModel}">
                                <views:RozkazEditorView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Border>
            </Grid>

            <!-- Pasek statusu -->
            <Border Grid.Row="3"
                    Background="{StaticResource SurfaceVariantBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,4">
                <Grid>
                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               FontSize="11"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Width="120"
                                 HorizontalAlignment="Right"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
