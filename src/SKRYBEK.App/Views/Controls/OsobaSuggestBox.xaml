<UserControl x:Class="SKRYBEK.App.Views.Controls.OsobaSuggestBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinWidth="120">
    <Grid>
        <TextBox x:Name="InputBox"
                 Style="{StaticResource DarkTextBox}"
                 Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
                 FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 TextChanged="InputBox_TextChanged"
                 LostFocus="InputBox_LostFocus"
                 PreviewKeyDown="InputBox_PreviewKeyDown" />

        <Popup x:Name="SuggestionsPopup"
               PlacementTarget="{Binding ElementName=InputBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    MinWidth="{Binding ActualWidth, ElementName=InputBox}"
                    MaxHeight="180">
                <ListBox x:Name="SuggestionsList"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="SuggestionsList_SelectionChanged"
                         MouseLeftButtonUp="SuggestionsList_MouseLeftButtonUp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,1">
                                <TextBlock Text="{Binding StopienINazwisko}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ForegroundBrush}" />
                                <TextBlock Text="{Binding Stanowisko}"
                                           FontSize="10"
                                           Foreground="{StaticResource ForegroundMutedBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</UserControl>
