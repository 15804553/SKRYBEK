<Window x:Class="SKRYBEK.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:SKRYBEK.App.Views.Chrome"
        Title="SKRYBEK — Logowanie"
        Icon="/Resources/skrybek.ico"
        Width="420" Height="460"
        MinWidth="360" MinHeight="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <chrome:SkrybekTitleBar Grid.Row="0"
                                    Title="SKRYBEK — Logowanie"
                                    ShowMinimizeButton="False"
                                    ShowMaximizeButton="False" />

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        Margin="40,20,40,40">

                <!-- Logo -->
                <Image Source="/Resources/skrybek_logo.png"
                       Height="96"
                       Margin="0,0,0,18"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- Tytuł -->
                <TextBlock Text="SKRYBEK"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource ForegroundBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Text="System Rozkazu Dziennego JRG"
                           FontSize="11"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28" />

                <!-- Lista użytkowników -->
                <TextBlock Text="Użytkownik"
                           Style="{StaticResource FormLabel}"
                           Margin="0,0,0,4" />
                <ComboBox x:Name="UzytkownikCombo"
                          ItemsSource="{Binding Uzytkownicy}"
                          SelectedItem="{Binding WybranyUzytkownik, Mode=TwoWay}"
                          DisplayMemberPath="NazwaZmiany"
                          IsEditable="True"
                          Style="{StaticResource DarkComboBox}"
                          Margin="0,0,0,16"
                          KeyDown="Input_KeyDown" />

                <!-- Hasło -->
                <TextBlock Text="Hasło"
                           Style="{StaticResource FormLabel}"
                           Margin="0,0,0,4"
                           Visibility="{Binding HasloWymagane, Converter={StaticResource BoolToVisibilityConverter}}" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource DarkPasswordBox}"
                             Margin="0,0,0,4"
                             KeyDown="Input_KeyDown"
                             Visibility="{Binding HasloWymagane, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Info PA (brak hasła) -->
                <TextBlock Text="Konto PA nie wymaga hasła"
                           FontSize="11"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           FontStyle="Italic"
                           Margin="0,0,0,4"
                           Visibility="{Binding HasloWymagane, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <!-- Błąd -->
                <TextBlock Text="{Binding Blad}"
                           Foreground="{StaticResource AlertBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,8,0,8"
                           Visibility="{Binding Blad, Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- Przycisk Zaloguj (hasło z code-behind — PasswordBox nie obsługuje bindingu) -->
                <Button Content="Zaloguj się"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnLoginClick"
                        IsDefault="True"
                        Margin="0,8,0,0" />

                <!-- Ładowanie -->
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Margin="0,10,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

            </StackPanel>
        </Grid>
    </Border>
</Window>
