<Window x:Class="SKRYBEK.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:SKRYBEK.App.Views.Chrome"
        xmlns:vm="clr-namespace:SKRYBEK.App.ViewModels"
        Title="SKRYBEK — Ustawienia"
        Icon="/Resources/skrybek.ico"
        Width="860" Height="680"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <chrome:SkrybekTitleBar Grid.Row="0"
                                     Title="SKRYBEK — Ustawienia"
                                     ShowMaximizeButton="False" />

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="8">

                <!-- ── Tab: Połączenia ─────────────────────────────────── -->
                <TabItem Header="Połączenia" Style="{StaticResource SkrybekTabItem}">
                    <ScrollViewer Margin="16">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,12">
                                Ścieżki baz CHOMIK i BOBER są odczytywane wyłącznie z pliku DatabasePatch.txt obok programu.
                                Aby je zmienić, edytuj plik i uruchom SKRYBEK ponownie.
                            </TextBlock>

                            <TextBlock Text="Baza danych BOBER"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding SciezkaBoberBazy}"
                                         IsReadOnly="True"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding TestBoberConnectionCommand}" />
                            </Grid>

                            <TextBlock Text="Baza danych CHOMIK"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,8,0,6" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding SciezkaChomikBazy}"
                                         IsReadOnly="True"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding TestChomikConnectionCommand}" />
                            </Grid>

                            <TextBlock Text="Nr JRG"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,8,0,6" />
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding NrJrg, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60"
                                     HorizontalAlignment="Left" />

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Tab: Pojazdy ────────────────────────────────────── -->
                <TabItem Header="Pojazdy" Style="{StaticResource SkrybekTabItem}">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Content="＋ Dodaj pojazd"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding DodajSamochodCommand}"
                                IsEnabled="{Binding CanEditPojazdy}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10" />

                        <DataGrid Grid.Row="1"
                                  Style="{StaticResource SkrybekDataGrid}"
                                  ItemsSource="{Binding Samochody}"
                                  SelectedItem="{Binding Wybranysamochod}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="{Binding CanEditPojazdy, Converter={StaticResource InverseBoolConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nazwa"
                                                    Binding="{Binding Nazwa, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*"
                                                    MinWidth="180"
                                                    CellStyle="{StaticResource SkrybekCell}"
                                                    HeaderStyle="{StaticResource SkrybekColumnHeader}" />
                                <DataGridTemplateColumn Header="Typ" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Typ, Converter={StaticResource TypSamochoduToEtykietaConverter}}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.TypySamochodow,
                                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      SelectedItem="{Binding Typ, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="True"
                                                      Style="{StaticResource DarkComboBox}"
                                                      Margin="0">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource TypSamochoduToEtykietaConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Pozycji"
                                                    Binding="{Binding LiczbaPozycji, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70"
                                                    CellStyle="{StaticResource SkrybekCell}"
                                                    HeaderStyle="{StaticResource SkrybekColumnHeader}" />
                                <DataGridTextColumn Header="Kolejność"
                                                    Binding="{Binding Kolejnosc, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="80"
                                                    CellStyle="{StaticResource SkrybekCell}"
                                                    HeaderStyle="{StaticResource SkrybekColumnHeader}" />
                                <DataGridTemplateColumn Header="Akcje" Width="Auto" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding DataContext.CanEditPojazdy,
                                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button Content="Zapisz"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,2"
                                                        FontSize="11"
                                                        Command="{Binding DataContext.ZapiszSamochodCommand,
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,6,0" />
                                                <Button Content="Usuń"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,2"
                                                        FontSize="11"
                                                        Command="{Binding DataContext.UsunSamochodCommand,
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Tab: Użytkownicy ────────────────────────────────── -->
                <TabItem Header="Użytkownicy"
                         Style="{StaticResource SkrybekTabItem}"
                         Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Content="＋ Dodaj użytkownika"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding DodajUzytkownikaCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10" />

                        <DataGrid Grid.Row="1"
                                  Style="{StaticResource SkrybekDataGrid}"
                                  ItemsSource="{Binding Uzytkownicy}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="120"
                                                    CellStyle="{StaticResource SkrybekCell}"
                                                    HeaderStyle="{StaticResource SkrybekColumnHeader}" />
                                <DataGridComboBoxColumn Header="Rola"
                                                        SelectedValueBinding="{Binding Role}"
                                                        Width="120"
                                                        HeaderStyle="{StaticResource SkrybekColumnHeader}">
                                    <DataGridComboBoxColumn.EditingElementStyle>
                                        <Style TargetType="ComboBox" BasedOn="{StaticResource EditableDarkComboBox}">
                                            <Setter Property="IsEditable" Value="True" />
                                        </Style>
                                    </DataGridComboBoxColumn.EditingElementStyle>
                                    <DataGridComboBoxColumn.ElementStyle>
                                        <Style TargetType="ComboBox" BasedOn="{StaticResource EditableDarkComboBox}">
                                            <Setter Property="IsEditable" Value="True" />
                                        </Style>
                                    </DataGridComboBoxColumn.ElementStyle>
                                </DataGridComboBoxColumn>
                                <DataGridTextColumn Header="Zmiana" Binding="{Binding NumerZmiany}" Width="70"
                                                    CellStyle="{StaticResource SkrybekCell}"
                                                    HeaderStyle="{StaticResource SkrybekColumnHeader}" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Zapisz"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,2" FontSize="11"
                                                        Command="{Binding DataContext.ZapiszUzytkownikaCommand,
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,6,0" />
                                                <Button Content="Zmień hasło"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,2" FontSize="11"
                                                        Command="{Binding DataContext.ZmienHasloCommand,
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,6,0" />
                                                <Button Content="Usuń"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="6,2" FontSize="11"
                                                        Command="{Binding DataContext.UsunUzytkownikaCommand,
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Tab: Backup ─────────────────────────────────────── -->
                <TabItem Header="Backup" Style="{StaticResource SkrybekTabItem}">
                    <StackPanel Margin="16">
                        <TextBlock Text="Backup bazy danych"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource ForegroundMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,16">
                            Program automatycznie tworzy backup każdego miesiąca przy starcie.
                            Pliki backupu są przechowywane w katalogu BACKUP\ obok programu z rozszerzeniem .bck.
                        </TextBlock>
                        <Button Content="Wykonaj backup teraz"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding WykonajBackupCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- Stopka: zapisz + status -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceVariantBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Zapisz zmiany"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ZapiszUstawieniaCommand}"
                            Padding="16,6"
                            MinWidth="130" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
