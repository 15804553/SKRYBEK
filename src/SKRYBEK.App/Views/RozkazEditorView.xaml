<UserControl x:Class="SKRYBEK.App.Views.RozkazEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SKRYBEK.App.ViewModels"
             xmlns:ctrl="clr-namespace:SKRYBEK.App.Views.Controls">

    <Grid x:Name="EditorRootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PersonelColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ PANEL PERSONELU (lewy) — widoczność w ApplyAccountMode ═══ -->
        <Grid x:Name="PersonelPanelHost"
              Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="4" />
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceVariantBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tytuł panelu -->
                <StackPanel Grid.Row="0" Margin="10,10,10,6">
                    <TextBlock Text="DOSTĘPNY PERSONEL"
                               Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="{Binding PersonelInfo}"
                               FontSize="10"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Filtry -->
                <StackPanel Grid.Row="1" Margin="8,0,8,6">
                    <TextBlock Text="Filtruj wg uprawnień:"
                               Style="{StaticResource FormLabel}"
                               Margin="0,0,0,4" />
                    <WrapPanel>
                        <CheckBox Content="kat. C" IsChecked="{Binding FilterKierowcaC}" Margin="0,0,8,4"
                                  Foreground="{StaticResource ForegroundBrush}" />
                        <CheckBox Content="kat. C+E" IsChecked="{Binding FilterKierowcaCE}" Margin="0,0,8,4"
                                  Foreground="{StaticResource ForegroundBrush}" />
                        <CheckBox Content="Nurek" IsChecked="{Binding FilterNurek}" Margin="0,0,8,4"
                                  Foreground="{StaticResource ForegroundBrush}" />
                        <CheckBox Content="KPP" IsChecked="{Binding FilterKPP}" Margin="0,0,8,4"
                                  Foreground="{StaticResource ForegroundBrush}" />
                    </WrapPanel>
                    <ComboBox IsEditable="True"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding DostepneFunkcje}"
                              SelectedItem="{Binding FilterFunkcja}"
                              Margin="0,4,0,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Wyczyść filtry"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetujFiltrCommand}"
                            HorizontalAlignment="Left"
                            Padding="8,3"
                            FontSize="11" />
                </StackPanel>

                <!-- Lista personelu -->
                <ListBox Grid.Row="2"
                         x:Name="PersonelList"
                         ItemsSource="{Binding Przefiltrowane}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,2"
                                    Padding="6,4"
                                    CornerRadius="3"
                                    Background="{Binding Converter={StaticResource FunkcjonariuszBoberTloConverter}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" FontSize="12"
                                               Foreground="{Binding Converter={StaticResource FunkcjonariuszBoberKolorConverter}}"
                                               Text="{Binding StopienINazwisko}" />
                                    <TextBlock FontSize="10"
                                               Opacity="0.85"
                                               Foreground="{Binding Converter={StaticResource FunkcjonariuszBoberKolorConverter}}"
                                               Text="{Binding Stanowisko}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}" ResizeBehavior="PreviousAndNext" />
        </Grid>

        <!-- ═══ OBSZAR EDYTORA (prawy) ═══ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <StackPanel Margin="16,12,16,16">

                <!-- Nagłówek rozkazu -->
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ROZKAZ DZIENNY NR "
                                       FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding NumerRozkazu, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Width="64" FontWeight="Bold" FontSize="16"
                                     Padding="6,4"
                                     IsReadOnly="{Binding IsReadOnly}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="/"
                                       FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       VerticalAlignment="Center" Margin="2,0" />
                            <TextBlock Text="{Binding Data.Year}"
                                       FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Text="Na dzień:"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <DatePicker SelectedDate="{Binding DataDateTime, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CzyZatwierdzony, Converter={StaticResource InverseBoolConverter}}"
                                        Style="{StaticResource DarkDatePicker}"
                                        Width="148"
                                        Height="34" />
                        </StackPanel>

                        <!-- Przyciski akcji -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                            <!-- Akceptacja rozkazu (wymaganie 3) -->
                            <Border Background="#2E7D32" CornerRadius="4" Padding="10,5"
                                    Margin="0,0,8,0"
                                    Visibility="{Binding CzyZatwierdzony, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="✔  ZATWIERDZONY"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="White" />
                            </Border>
                            <Button x:Name="BtnZatwierdzRozkaz"
                                    Content="✔  Zatwierdź rozkaz"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#2E7D32"
                                    Command="{Binding AkceptujRozkazCommand}"
                                    Visibility="Collapsed"
                                    Margin="0,0,8,0" />
                            <Button x:Name="BtnOdblokujRozkaz"
                                    Content="🔓  Odblokuj"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding OdblokujRozkazCommand}"
                                    Visibility="Collapsed"
                                    Margin="0,0,8,0" />
                            <Button x:Name="BtnZapiszRozkaz"
                                    Content="💾  Zapisz"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ZapiszCommand}"
                                    IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}" />
                        </StackPanel>
                        <Button Grid.Column="3"
                                Content="📄  Eksport Word"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding EksportujDoWordCommand}" />
                    </Grid>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           Margin="0,0,0,10"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- ── 1) SŁUŻBA ────────────────────────────────────────── -->
                <TextBlock Text="1)   SŁUŻBA"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding Sluzba}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PozycjaSluzbyViewModel}">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding NazwaStanowiska, Mode=OneWay}"
                                               Foreground="{StaticResource ForegroundBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="13" />
                                    <TextBlock Grid.Column="1"
                                               Text="-"
                                               Foreground="{StaticResource ForegroundMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="2"
                                              IsEditable="True"
                                              Style="{StaticResource EditableDarkComboBox}"
                                              SelectedItem="{Binding WybranyItem, UpdateSourceTrigger=PropertyChanged}"
                                              Text="{Binding TekstOsoby, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding DostepneOsoby}"
                                              IsReadOnly="{Binding DataContext.IsReadOnly,
                                                           RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10"
                                                                   FontStyle="Italic"
                                                                   Foreground="{StaticResource ForegroundMutedBrush}"
                                                                   Margin="4,2,4,1" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:OsobaComboBoxItem}">
                                                <TextBlock Text="{Binding StopienINazwisko}"
                                                           ToolTip="{Binding TooltipText}"
                                                           Foreground="{Binding KolorBoberaForeground}"
                                                           FontWeight="{Binding CzySugerowana,
                                                               Converter={StaticResource BoolToFontWeightConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ── 2) PODZIAŁ BOJOWY ─────────────────────────────────── -->
                <TextBlock Text="2)   PODZIAŁ BOJOWY"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding PodzialBojowy}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SamochodViewModel}">
                                <Border Margin="6,4"
                                        MinWidth="200"
                                        BorderBrush="{Binding CzyPodstawowy, Converter={StaticResource SamochodTypToBorderBrushConverter}}"
                                        BorderThickness="2"
                                        CornerRadius="4"
                                        Padding="8,6">
                                    <StackPanel>
                                        <!-- Nazwa pojazdu/grupy -->
                                        <Border Background="{StaticResource AccentBrush}"
                                                CornerRadius="3"
                                                Padding="6,3"
                                                Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Nazwa}"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <!-- Pozycje -->
                                        <ItemsControl ItemsSource="{Binding Pozycje}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:PozycjaSamochoduViewModel}">
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="38" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding NumerPozycji}"
                                                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding OznaczeniePozycji}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Margin="5,0,0,0"
                                                                       Foreground="{Binding Pozycja, Converter={StaticResource PozycjaOznaczenieBrushConverter}}"
                                                                       Visibility="{Binding MaOznaczenie, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        </StackPanel>
                                                        <ComboBox Grid.Column="1"
                                                                  IsEditable="True"
                                                                  Style="{StaticResource EditableDarkComboBox}"
                                                                  SelectedItem="{Binding WybranyItem, UpdateSourceTrigger=PropertyChanged}"
                                                                  Text="{Binding TekstOsoby, UpdateSourceTrigger=PropertyChanged}"
                                                                  ItemsSource="{Binding DostepneOsoby}"
                                                                  IsReadOnly="{Binding DataContext.IsReadOnly,
                                                                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  FontSize="11">
                                                            <ComboBox.GroupStyle>
                                                                <GroupStyle>
                                                                    <GroupStyle.HeaderTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontSize="9"
                                                                                       FontStyle="Italic"
                                                                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                                                                       Margin="4,1,4,1" />
                                                                        </DataTemplate>
                                                                    </GroupStyle.HeaderTemplate>
                                                                </GroupStyle>
                                                            </ComboBox.GroupStyle>
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:OsobaComboBoxItem}">
                                                                    <TextBlock Text="{Binding StopienINazwisko}"
                                                                               ToolTip="{Binding TooltipText}"
                                                                               Foreground="{Binding KolorBoberaForeground}"
                                                                               FontWeight="{Binding CzySugerowana,
                                                                                   Converter={StaticResource BoolToFontWeightConverter}}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ── DYŻURNI RATOWNICY MEDYCZNI PSP ───────────────────── -->
                <TextBlock Text="DYŻURNI RATOWNICY MEDYCZNI PSP"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="1.  " Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            <ctrl:OsobaSuggestBox Text="{Binding RatownikMedyczny1, UpdateSourceTrigger=PropertyChanged}"
                                                  Personel="{Binding WszystkieOsoby}"
                                                  IsReadOnly="{Binding IsReadOnly}"
                                                  Width="180" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="2.  " Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            <ctrl:OsobaSuggestBox Text="{Binding RatownikMedyczny2, UpdateSourceTrigger=PropertyChanged}"
                                                  Personel="{Binding WszystkieOsoby}"
                                                  IsReadOnly="{Binding IsReadOnly}"
                                                  Width="180" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── 3) ZAJĘCIA ──────────────────────────────────────── -->
                <TextBlock Text="3)   ZAJĘCIA"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />
                <TextBox Style="{StaticResource DarkSpellCheckTextBox}"
                         Text="{Binding Zajecia, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsReadOnly}"
                         TextWrapping="Wrap"
                         MinHeight="50"
                         Margin="0,0,0,12"
                         AcceptsReturn="True" />

                <!-- ── 4) NIEOBECNI W SŁUŻBIE ───────────────────────────── -->
                <TextBlock Text="4)   NIEOBECNI W SŁUŻBIE"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding NieobecniGrupy}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NieobecniGroupViewModel}">
                                <Border Margin="4" MinWidth="180"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Tytul}"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:NieobecnyViewModel}">
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ctrl:OsobaSuggestBox Grid.Column="0"
                                                                              Text="{Binding Nazwisko, UpdateSourceTrigger=PropertyChanged}"
                                                                              Personel="{Binding DataContext.WszystkieOsoby,
                                                                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              IsReadOnly="{Binding DataContext.IsReadOnly,
                                                                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              FontSize="12" />
                                                        <Button Grid.Column="1"
                                                                Content="✕"
                                                                Style="{StaticResource ChromeIconButton}"
                                                                Width="22" Height="22" FontSize="10"
                                                                IsEnabled="{Binding DataContext.IsReadOnly,
                                                                           RelativeSource={RelativeSource AncestorType=UserControl},
                                                                           Converter={StaticResource InverseBoolConverter}}"
                                                                Command="{Binding DataContext.UsunNieobecnegoCommand,
                                                                         RelativeSource={RelativeSource AncestorType=Border}}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="＋ Dodaj"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DodajNieobecnegoCommand}"
                                                IsEnabled="{Binding DataContext.IsReadOnly,
                                                           RelativeSource={RelativeSource AncestorType=UserControl},
                                                           Converter={StaticResource InverseBoolConverter}}"
                                                HorizontalAlignment="Left"
                                                Padding="6,2"
                                                FontSize="11"
                                                Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ── 5) UWAGI ──────────────────────────────────────────── -->
                <TextBlock Text="5)   UWAGI"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,6" />
                <TextBox Style="{StaticResource DarkSpellCheckTextBox}"
                         Text="{Binding Uwagi, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsReadOnly}"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         Margin="0,0,0,16"
                         AcceptsReturn="True" />

                <!-- Stopka -->
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}"
                           FontSize="11"
                           HorizontalAlignment="Right">
                    <Run Text="Rozkaz podpisał D-ca JRG-" />
                    <Run Text="{Binding NrJrg}" FontWeight="Bold" />
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
